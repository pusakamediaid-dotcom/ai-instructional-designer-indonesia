{
  "name": "ai-instructional-designer-indonesia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Asisten AI berbasis Gemini untuk membantu guru Indonesia menyusun perangkat pembelajaran (Modul Ajar, LKPD, Bahan Ajar) dengan metode Backward Design (UbD). Mendukung dua jalur regulasi: Kemendikbud & Kemenag.",
  "author": "Pusaka Media ID <pusaka.media.id@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/pusakamediaid-dotcom/ai-instructional-designer-indonesia#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/pusakamediaid-dotcom/ai-instructional-designer-indonesia.git"
  },
  "bugs": {
    "url": "https://github.com/pusakamediaid-dotcom/ai-instructional-designer-indonesia/issues"
  },
  "keywords": [
    "education",
    "indonesia",
    "curriculum",
    "kurikulum-merdeka",
    "modul-ajar",
    "backward-design",
    "understanding-by-design",
    "gemini-api",
    "react",
    "typescript",
    "tailwindcss",
    "ai"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "serverless-http": "^4.0.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.8.22",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
